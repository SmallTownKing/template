	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"tabBar": {
		"color": "#666666",
		"selectedColor": "#000000",
		"backgroundColor": "#fff",
		"fontSize": "10px",
		"iconWidth": "24px",
		"height": "70px",
		"list": [
			{
				"pagePath": "pages/index/index",
				"iconPath": "static/tabbar/t2.png",
				"selectedIconPath": "static/tabbar/t1.png",
				"text": "\u6e38\u620f"
			},
			{
				"pagePath": "pages/card-release/index",
				"iconPath": "static/tabbar/t4.png",
				"selectedIconPath": "static/tabbar/t3.png",
				"text": "\u5361\u724c"
			},
			{
				"pagePath": "pages/market/index",
				"iconPath": "static/tabbar/t6.png",
				"selectedIconPath": "static/tabbar/t5.png",
				"text": "\u96c6\u5e02"
			},
			{
				"pagePath": "pages/warehouse/index",
				"iconPath": "static/tabbar/t8.png",
				"selectedIconPath": "static/tabbar/t7.png",
				"text": "\u4ed3\u5e93"
			},
			{
				"pagePath": "pages/user-center/index",
